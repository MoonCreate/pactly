{
  "compilerOptions": {
    "lib": ["es2023", "dom"],
    "module": "preserve",
    "target": "es2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["index.ts", "chain.ts", "ignition/**/*.ts"]
}
